{
  "name": "@chaireblockchainulaval/bnaas-connect",
  "version": "0.1.0",
  "description": "SDK « Se connecter avec BNAAS » — obtention d'un jeton d'identité notariale via OAuth 2.0 + PKCE (popup ou redirection).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bnaas",
    "oauth",
    "pkce",
    "notarial",
    "sdk"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChaireBlockchainULaval/bnaas-connect.git"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
